# Kopieer dit bestand naar .env en vul de waarden in:
#   cp .env.example .env

# --- LLM backend ---
# Google Gemini API key (demo). Verkrijg via https://aistudio.google.com/apikey
# In productie vervang je dit door een Azure OpenAI key + endpoint (zie docs/architectuur.md).
GOOGLE_API_KEY=jouw-gemini-key-hier

# --- Auth ---
# true = login vereist (aanbevolen). WEBUI_AUTH=false is one-way en niet aan te raden.
WEBUI_AUTH=true

# Admin wordt automatisch aangemaakt op een lege gebruikers-tabel (no-op als er al users zijn).
# Daarom kan signup uit blijven staan.
ENABLE_SIGNUP=false

# JWT-signing key. Zet deze zelf en pin hem vast, anders worden alle sessies ongeldig
# bij elke container-herstart ("session expired" / 401). Genereer er een met:
#   openssl rand -hex 32
WEBUI_SECRET_KEY=genereer-met-openssl-rand-hex-32

# Bootstrap-admin (alleen gebruikt bij de allereerste start op een lege database).
WEBUI_ADMIN_EMAIL=admin@example.org
WEBUI_ADMIN_PASSWORD=verander-dit-wachtwoord

# --- Overig ---
# Poort waarop OdionChat lokaal bereikbaar is (achter een reverse proxy ook 3000).
PORT=3000
