# Kopieer dit bestand naar .env en vul je waarden in:
#   cp .env.example .env

# Azure AI Foundry — OpenAI-compatible endpoint (Keys and Endpoint in Azure Portal)
OPENAI_API_BASE_URLS=https://<resource-name>.openai.azure.com/openai/v1/
AZURE_OPENAI_API_KEY=jouw-foundry-api-key-hier

# Deployment names (moeten matchen met Foundry deployments)
AZURE_DEPLOYMENT_FAST=odionchat-fast
AZURE_DEPLOYMENT_PRO=odionchat-pro

# --- Auth ---
# true = login vereist (aanbevolen). WEBUI_AUTH=false is one-way en niet aan te raden.
WEBUI_AUTH=true

# Eerste boot: zet ENABLE_SIGNUP=true om admin-account aan te maken,
# daarna terugzetten naar false voor productie.
ENABLE_SIGNUP=true

# Poort waarop OdionChat bereikbaar is (lokaal 3000, achter reverse proxy ook 3000)
PORT=3000
