# Kopieer dit bestand naar .env en vul je API key in:
#   cp .env.example .env

# Google Gemini API key (verkrijg via https://aistudio.google.com/apikey)
GOOGLE_API_KEY=jouw-gemini-key-hier

# Authenticatie (true = login vereist, false = open toegang voor demo)
WEBUI_AUTH=true

# Eerste boot: zet ENABLE_SIGNUP=true om admin-account aan te maken,
# daarna terugzetten naar false voor productie.
ENABLE_SIGNUP=true

# Poort waarop OdionChat bereikbaar is (lokaal 3000, achter Caddy ook 3000)
PORT=3000
